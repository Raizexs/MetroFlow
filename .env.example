# Copiar a .env en la raíz (no commitear .env)

# Local / Docker
DATABASE_URL=postgresql+asyncpg://ocupacion:ocupacion@localhost:5432/ocupacion

# Render: convertir postgres:// a postgresql+asyncpg://
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Vercel (build-time)
VITE_API_URL=http://localhost:8000

# Render API — origen del dashboard en producción
CORS_EXTRA_ORIGIN=https://tu-proyecto.vercel.app

# URLs cloud (para scripts/verify-rubric.ps1)
# API_URL=https://tu-api.onrender.com
# FRONTEND_URL=https://tu-proyecto.vercel.app
